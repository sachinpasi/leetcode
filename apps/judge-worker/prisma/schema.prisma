generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Problem {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  difficulty  String
  category    String
  createdAt   DateTime     @default(now())
  submissions Submission[]
  testCases   TestCase[]
}

model TestCase {
  id        Int     @id @default(autoincrement())
  problemId Int
  input     String
  output    String
  problem   Problem @relation(fields: [problemId], references: [id])
}

model Submission {
  id        Int      @id @default(autoincrement())
  problemId Int
  code      String
  language  String
  status    String
  result    String?
  createdAt DateTime @default(now())
  problem   Problem  @relation(fields: [problemId], references: [id])
}
