generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Problem {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  difficulty  String
  category    String
  testCases   TestCase[]
  submissions Submission[]
  createdAt   DateTime @default(now())
}

model TestCase {
  id        Int     @id @default(autoincrement())
  input     String
  output    String
  problem   Problem @relation(fields: [problemId], references: [id])
  problemId Int
}

model Submission {
  id        Int      @id @default(autoincrement())
  problem   Problem  @relation(fields: [problemId], references: [id])
  problemId Int
  code      String
  language  String
  status    String   // PENDING, ACCEPTED, WRONG_ANSWER, ERROR
  result    String?  // JSON string of execution results
  createdAt DateTime @default(now())
}
